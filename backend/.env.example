# 角色资产库 —— 本地配置（独立，不与其他项目共用）
# 复制本文件为 .env 后填入。留空时 AI 功能不可用，其余功能正常。

# OpenRouter 代理 —— 文字与图片共用同一 key、同一地址
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://proxy.offerin.cn/openrouter/api/v1

# 文字模型（写提示词 / 解析字段）
TEXT_MODEL=anthropic/claude-opus-4.7

# 图片模型
IMAGE_MODEL=openai/gpt-5.4-image-2
# 出图宽高比（3:2 宽幅适合设计稿）与分辨率（1K / 2K）
IMAGE_ASPECT_RATIO=3:2
IMAGE_SIZE=2K

# Neon Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# 火山引擎 TOS（S3 兼容访问）
TOS_BUCKET=
TOS_REGION=
TOS_ENDPOINT=https://tos-s3-cn-beijing.volces.com
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
